# ---------------------------------------------------------------------
# Supabase — create a project at https://supabase.com, then copy these
# from Project Settings → API.
# ---------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Service role — server-side only (never exposed to the browser).
# Used by the invitation/admin actions to bypass RLS where required.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ---------------------------------------------------------------------
# SMS provider (Eskiz.uz — common in Uzbekistan).
# Leave SMS_PROVIDER=mock in dev — OTPs will be logged to the server
# console AND surfaced in the UI toast so you can test end-to-end.
# ---------------------------------------------------------------------
SMS_PROVIDER=mock                    # mock | eskiz
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546                      # alphanumeric sender id

# ---------------------------------------------------------------------
# Session / security
# ---------------------------------------------------------------------
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_LOCKOUT_MINUTES=30
INVITATION_TTL_DAYS=7
